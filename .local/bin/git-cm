#!/usr/bin/env python3

"""
Tool to write commits from the CLI, just like git commit -m "Message". Except
it's also used to write a beautiful formatted CHANGELOG.md

usage: git-cm [-h] [-v VERSION] [-b BODY] [-a AUTHORS [AUTHORS ...]] [--host {github,gitlab,codeberg}] message

positional arguments:
  message

options:
  -h, --help            show this help message and exit
  -v, --version VERSION
                        Project version
  -b, --body BODY       Commit body
  -a, --authors AUTHORS [AUTHORS ...]
                        Author and co-author usernames
  --host {github,gitlab,codeberg}
                        Author profile host (default: github)
"""

import sys
import re
import subprocess
from pathlib import Path
import argparse

# Config
CHANGELOG_SCHEMA = {
    "feat": {
        "section": "Added",
    },
    "fix": {
        "section": "Fixed",
    },
    "refactor": {
        "section": "Changed",
    },
    "perf": {
        "section": "Changed",
    },
    "bump": {
        "section": "Miscellaneous",
    },
    "deprecate": {
        "section": "Removed",
    },
}

# Splits commit message
def parse_commit_message(msg):
    pattern = r'^(\w+)(!)?(?:\(([^)]+)\))?:\s+(.+)$'
    match = re.match(pattern, msg)
    if not match:
        return None, None, None, False
    ctype = match.group(1).lower()
    breaking = bool(match.group(2))
    scope = match.group(3)
    desc = match.group(4).strip()
    return ctype, scope, desc, breaking

# Fallback version based on Git tag
def get_version():
    try:
        result = subprocess.run(
            ['git', 'tag', '-l', '--sort=-version:refname'],
            capture_output=True, text=True, check=True
        )
        tags = [t for t in result.stdout.splitlines() if t]
        if not tags:
            return "0.1.0"

        major, minor, patch = map(int, tags[0].lstrip('v').split('.'))
        return f"{major}.{minor}.{patch+1}"
    except Exception:
        return "0.1.0"

# Get latest hash
def git_short_hash():
    return subprocess.check_output(
        ['git', 'rev-parse', '--short', 'HEAD']
    ).decode().strip()

# Writes to CHANGELOG.md
def update_changelog(
    commit_type, scope, desc, version,
    breaking=False,
    authors=None,
    host="github"
):
    changelog = Path("CHANGELOG.md")

    content = changelog.read_text() if changelog.exists() else ""
    lines = content.splitlines()

    version_header = f"# [{version}]"
    if version_header not in lines:
        lines = [version_header, ""] + lines

    v_idx = lines.index(version_header)

    def ensure_section(title):
        """Ensure a section exists under the current version"""
        for i in range(v_idx + 1, len(lines)):
            if lines[i].startswith("# ["):
                break
            if lines[i].strip() == title:
                return i

        insert_at = v_idx + 1
        lines.insert(insert_at, title)
        lines.insert(insert_at + 1, "")
        return insert_at

    if breaking:
        section = "Breaking Changes"
    else:
        meta = CHANGELOG_SCHEMA.get(commit_type)
        if not meta:
            return
        section = meta["section"]

    sec_title = f"## {section}"
    sec_idx = ensure_section(sec_title)

    commit_hash = git_short_hash()
    scope_txt = f" [{scope}]" if scope else ""
    author_txt = format_authors(authors, host)

    entry = f"-{scope_txt} {commit_hash} {desc.capitalize()} {author_txt}"

    lines.insert(sec_idx + 2, entry)
    changelog.write_text("\n".join(lines) + "\n")

# Reference the author and co-author profiles
def format_authors(authors, host):
    if not authors:
        return ""

    base_urls = {
        "github": "https://github.com",
        "gitlab": "https://gitlab.com",
        "codeberg": "https://codeberg.org",
    }

    base = base_urls.get(host, base_urls["github"])

    links = [
        f"[{a}]({base}/{a})"
        for a in authors
    ]

    return "- by " + ", ".join(links)

def main():
    p = argparse.ArgumentParser()
    p.add_argument("-v", "--version", help="Project version")
    p.add_argument("-b", "--body", help="Commit body")
    p.add_argument("-a", "--authors", nargs="+", help="Author and co-author usernames")
    p.add_argument(
        "--host",
        choices=["github", "gitlab", "codeberg"],
        default="github",
    help="Author profile host (default: github)"
)
    p.add_argument("message")
    args = p.parse_args()

    ctype, scope, desc, breaking = parse_commit_message(args.message)

    if not ctype:
        print("Invalid commit format")
        print("Usage: type(scope): description")
        sys.exit(1)

    version = args.version or get_version()

    cmd = ["git", "commit", "-m", args.message]
    if args.body:
        cmd.extend(["-m", args.body])
    try: subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError:
        None

    update_changelog(
        ctype, scope, desc,
        version,
        breaking=breaking,
        authors=args.authors,
        host=args.host
    )

if __name__ == "__main__":
    main()
